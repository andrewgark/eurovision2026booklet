\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{booklet}[2026/04/20 Eurovision booklet style]

\RequirePackage{geometry}
\RequirePackage{fontspec}
\RequirePackage{polyglossia}
\RequirePackage{graphicx}
\RequirePackage{xcolor}
\RequirePackage{multicol}
\RequirePackage{hyperref}
\RequirePackage{parskip}
\RequirePackage{fancyhdr}
\RequirePackage{enumitem}
\RequirePackage{microtype}
\RequirePackage{ragged2e}
\RequirePackage{setspace}

\geometry{
  a4paper,
  top=18mm,
  bottom=18mm,
  left=18mm,
  right=18mm
}

\setmainfont{Latin Modern Roman}
\setsansfont{Latin Modern Sans}
\setmonofont{Latin Modern Mono}

\setdefaultlanguage{english}
\setotherlanguage{russian}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\thepage}

\newcommand{\BookletTitle}[1]{%
  {\Huge\bfseries #1}\par\vspace{6mm}%
}

\newcommand{\SectionTitle}[1]{%
  {\Large\bfseries #1}\par\vspace{2mm}%
}

\newcommand{\Muted}[1]{\textcolor{black!65}{#1}}

\newcommand{\ClampTextBlock}[2]{%
  \begingroup
  \setlength{\parskip}{0.6ex}%
  \setstretch{0.98}%
  \footnotesize
  \RaggedRight
  \begin{minipage}[t]{\linewidth}
    \setlength{\baselineskip}{#1}%
    #2%
  \end{minipage}
  \endgroup
}

\newcommand{\TwoColBlock}[2]{%
  \begin{minipage}[t]{0.49\textwidth}#1\end{minipage}\hfill%
  \begin{minipage}[t]{0.49\textwidth}#2\end{minipage}%
}

\newcommand{\AssetBox}[2]{%
  \begin{minipage}[t]{#1}
    \centering
    #2
  \end{minipage}%
}

