\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{booklet}[2026/04/24 Eurovision booklet style]

\RequirePackage{geometry}
\RequirePackage{fontspec}
\RequirePackage{polyglossia}
\RequirePackage{graphicx}
\RequirePackage{xcolor}
\RequirePackage{multicol}
\RequirePackage{hyperref}
\RequirePackage{parskip}
\RequirePackage{fancyhdr}
\RequirePackage{enumitem}
\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{etoolbox}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}
\RequirePackage{tikz}
\usetikzlibrary{calc,positioning}
% Full protrusion/expansion with \cyrillicfont (DejaVu Sans) can trigger
% "invalid font identifier when asking 'fontsize'" under LuaLaTeX + fontspec.
\RequirePackage[protrusion=false, expansion=false]{microtype}
\RequirePackage{ragged2e}
\RequirePackage{setspace}

\geometry{
  a4paper,
  top=10.5mm,
  bottom=12.5mm,
  left=11.5mm,
  right=11.5mm,
  footskip=7.0mm
}
% Default article \flushbottom can stretch white space; song pages are fixed
% blocks and we avoid arbitrary vertical stretch between hero and columns.
\raggedbottom
% Song pages use a very narrow left column (see \SongPage) with ragged
% \RaggedRight text and RU/EN hyphenation. TeX’s default \hbadness=1000 then
% emits a huge number of ``Underfull \hbox (badness 10000)'' log lines; the
% output is still acceptable (ragged/short last lines, narrow measure). For
% booklet-style sidebars, matching common practice: silence only these
% cosmetic underfull messages (overfull/overflows still use \hfuzz / etc.).
\hbadness=10000
\vbadness=10000

\setmainfont{DejaVu Sans}
\setsansfont{DejaVu Sans}
\setmonofont{DejaVu Sans Mono}
\newfontfamily{\cyrillicfont}{DejaVu Sans}
\newfontfamily{\cyrillicfontsf}{DejaVu Sans}
\newfontfamily{\cyrillicfonttt}{DejaVu Sans Mono}
\newfontfamily{\LyricsFont}{DejaVu Sans Condensed}
% Iteration 2 (layout): the song-page *left* column is a very tight measure; the
% same family in Condensed makes more break opportunities and pairs visually
% with the lyrics column (which already uses \LyricsFont). Cover/TOC/hero keep
% regular-width \MixedFont; only the three infopanels use this.
\newfontfamily{\InfoColumnFont}{DejaVu Sans Condensed}
% Default body uses the same sans everywhere — the cover, the intro "About"
% page, and the lyrics all render with the same typeface as the info panels
% and country pages. This avoids the jarring Computer-Modern-Roman fallback
% that used to appear on the intro pages under the English variant.
\renewcommand{\familydefault}{\sfdefault}
% \MixedBody is a catch-all family that renders Latin + Cyrillic + Hebrew +
% extended punctuation. Use it where data may contain unpredictable scripts
% (artist bios/facts in untranslated placeholders, song titles in original, etc).
\newfontfamily{\MixedFont}{DejaVu Sans}
\newcommand{\MixedBody}[1]{{\MixedFont #1}}
\newcommand{\InfoMixedBody}[1]{{\InfoColumnFont #1}}
\newcommand{\InfoNameLine}[1]{{\InfoColumnFont\bfseries\selectfont\normalsize #1}}

% Color emoji font for inline 🌈 / 🏳️‍🌈 / 📍-style icons. Noto Color Emoji
% only works in LuaLaTeX with the HarfBuzz renderer. Used by \RainbowEmoji.
\newfontface{\EmojiFont}{Noto Color Emoji}[Renderer=HarfBuzz, Scale=1.0]

\setdefaultlanguage{english}
\setotherlanguage{russian}
% Hebrew in lyrics: LuaHBTeX needs Script=Hebrew + HarfBuzz for correct shaping; \LyricsFont
% alone with \textdir TRT often reverses word order. Same Condensed family with explicit script.
\newfontfamily{\HebrewLyricsFont}{DejaVu Sans Condensed}[Renderer=HarfBuzz,Script=Hebrew]
\newcommand{\HebrewRun}[1]{%
  \begingroup
  \pardir TRT\textdir TRT
  \HebrewLyricsFont\selectfont
  #1%
  \endgroup
}

%% ---- Design tokens ---------------------------------------------------------
\definecolor{BookletInk}{HTML}{141922}         % deep near-black for body
\definecolor{BookletAccent}{HTML}{1E3A8A}      % Eurovision-ish deep blue
\definecolor{BookletAccent2}{HTML}{D72660}     % magenta accent
\definecolor{BookletGold}{HTML}{D6A84B}        % hero band + legacy accent
% Implied-odds pills (qualify / win): muted, one warm family, quiet on the page
\definecolor{BookletProbRed}{HTML}{B87870}
\definecolor{BookletProbAmber}{HTML}{C9B16A}
\definecolor{BookletProbGreen}{HTML}{6E9A78}
\definecolor{BookletSoft}{HTML}{F3F4F9}        % panel background
\definecolor{BookletRule}{HTML}{D9DDE5}        % hairline
\definecolor{BookletMuted}{HTML}{5B6370}       % muted text
\definecolor{BookletQueer}{HTML}{8B5CF6}       % soft violet for LGBTQ pill (less aggressive than red/magenta)
\definecolor{BookletYT}{HTML}{C7172A}          % YouTube-ish red, slightly muted

\hypersetup{colorlinks=true, linkcolor=BookletAccent, urlcolor=BookletAccent}

%% ---- Page chrome ----------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyfoot[C]{\color{BookletMuted}\footnotesize\sffamily\thepage}

% Per-song-page right-footer holder. Song pages call \SetSongFooter before
% \SongPage to drop their video links into the bottom-right of the page.
\newcommand{\BookletPageFooterContent}{}
\fancypagestyle{songpage}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
  \fancyfoot[C]{\color{BookletMuted}\footnotesize\sffamily\thepage}%
  \fancyfoot[R]{\BookletPageFooterContent}%
}
% \gdef (not \def): \SongPage wraps body in \begingroup...\endgroup before
% \newpage; a local \def would revert \BookletPageFooterContent to empty when
% the page ships, so the YouTube links would never appear in the PDF footer.
\newcommand{\SetSongFooter}[1]{%
  \gdef\BookletPageFooterContent{#1}%
  \thispagestyle{songpage}%
}

%% ---- Typography helpers ---------------------------------------------------
% (Legacy) Old cover title stack — kept for compatibility; not used in main template.
\newcommand{\BookletTitle}[1]{%
  {\sffamily\fontsize{26pt}{30pt}\selectfont\bfseries\color{BookletAccent} #1}\par\vspace{1mm}%
  {\color{BookletAccent2}\rule{28mm}{2pt}}\par\vspace{2.5mm}%
}

% \VariantPill{label} — pill badge (cover + reuse elsewhere if needed).
\newcommand{\VariantPill}[1]{%
  \begin{tikzpicture}[baseline=(p.base)]
    \node[
      fill=BookletAccent, text=white, rounded corners=2.5pt,
      inner xsep=8pt, inner ysep=3.5pt,
      font=\sffamily\bfseries\small
    ] (p) {#1};
  \end{tikzpicture}%
}

% ---- Cover page (page 1): centered booklet / event / variant + optional tagline ----
% Top line: small letterspaced label (“Booklet” / “Буклет”).
\newcommand{\CoverBookletLabel}[1]{%
  {\sffamily\color{BookletMuted}
   \fontsize{8.8pt}{11.5pt}\selectfont\bfseries
   \addfontfeature{LetterSpace=2.2}\MakeUppercase{#1}}%
}
% Main headline: event name.
\newcommand{\CoverEventHeadline}[1]{%
  \begingroup\centering
  {\sffamily\bfseries\fontsize{24pt}{28.5pt}\selectfont\color{BookletAccent} #1}\par
  \nointerlineskip\relax\vspace{0.65mm}%
  \nointerlineskip{\color{BookletAccent2!88!BookletGold}\rule{42mm}{1.3pt}}\par
  \nointerlineskip\relax\vspace{0.25mm}%
  \nointerlineskip{\color{BookletAccent!55}\rule{22mm}{0.5pt}}\par
  \vspace{0.5em}
  \endgroup
}
% Centred row with the phase pill (Semi-final, Overall, …).
\newcommand{\CoverVariantRow}[1]{%
  \begingroup\centering\nointerlineskip\relax
  \VariantPill{#1}\par
  \endgroup
}
% Optional per-variant text from sheets (can be multiline; already TeX-escaped in build).
\newcommand{\CoverSubtagline}[1]{%
  \begingroup\centering\color{BookletAccent2}
  \sffamily\fontseries{bf}\selectfont\fontsize{10.6pt}{13.0pt}
  #1\par
  \endgroup
}

\newcommand{\SectionTitle}[1]{%
  {\sffamily\Large\bfseries\color{BookletAccent} #1}\par
  \vspace{1mm}%
  {\color{BookletAccent}\rule{18mm}{1.2pt}}\par\vspace{2mm}%
}

% (Legacy) Was used for cover tagline; \CoverSubtagline supersedes it.
\newcommand{\VariantBookletSubtitle}[1]{%
  \CoverSubtagline{#1}%
}

% About-page / intro: bullet lists and spacing come from \IntroItemize in scripts/build.py.
\newenvironment{IntroItemize}{%
  \begin{itemize}[
    leftmargin=1.1em, rightmargin=0pt, labelwidth=0.65em, labelsep=0.35em,
    itemsep=0.2em, parsep=0pt, partopsep=0pt, topsep=0.12em, listparindent=0pt,
    label={\color{BookletAccent2}\textbullet}
  ]%
}{%
  \end{itemize}%
}

% About-page body: soft panel, accent rail, full-width (intro_text_* or about_text).
\newtcolorbox{introtextbox}{%
  enhanced, arc=3.1pt,
  colback=BookletSoft, colframe=BookletRule,
  boxrule=0.4pt, left=3.2mm, right=3.0mm, top=3.0mm, bottom=3.2mm,
  borderline west={2.4pt}{0pt}{BookletAccent},
  before skip=0pt, after skip=0pt,
  halign=flush left,
  fontupper={\sffamily\small\color{BookletInk}\selectfont\setstretch{1.09}},
  before upper={\RaggedRight\setlength{\parskip}{0.48em}\setlength{\parindent}{0pt}}%
}

% Tighter "Contents" head so the first page can list every country link
% (see also compact \TocItemLink and spacing in main.tex.j2 before it).
\newcommand{\TocSectionTitle}[1]{%
  {\sffamily\large\bfseries\color{BookletAccent} #1}\par
  \vspace{0.3mm}%
  {\color{BookletAccent}\rule{16mm}{0.9pt}}\par\vspace{0.8mm}%
}

% \TocItem{label} — arrow-led contents row with muted chevron.
\newcommand{\TocItem}[1]{%
  \noindent{\color{BookletAccent2}\small\textbullet}\hspace{2.2mm}{\normalsize #1}\par\vspace{1.2mm}%
}

% Country flag in contents (regional-indicator pair; must use Noto Color Emoji).
\newcommand{\TocFlagEmoji}[1]{%
  \ifstrempty{#1}{}{{\EmojiFont\fontsize{7.4pt}{7.4pt}\selectfont #1}\hspace{1.5pt}}%
}

% \TocItemLink{label}{before}{linked} — arrow-led contents row; only `linked` is
% wrapped in \hyperref. Keep regional-indicator flags in `before` (e.g.\
% \TocFlagEmoji{…}): inside \hyperref, LuaLaTeX + fontspec often fail to render
% Noto Color Emoji (two tofu boxes) and line breaks go wrong.
\newcommand{\TocItemLink}[3]{%
  \noindent\RaggedRight\footnotesize
  \strut{\color{BookletAccent2}\scriptsize\textbullet}\hspace{1.4mm}%
  #2%
  \hyperref[#1]{#3}%
  \par\vspace{0.2mm}%
}

\newcommand{\Muted}[1]{\textcolor{BookletMuted}{#1}}

% Lightly-emphasized label for small metadata rows. No CAPS.
\newcommand{\Kicker}[1]{%
  {\sffamily\scriptsize\bfseries #1}%
}

\newcommand{\Rule}{\par\noindent\textcolor{BookletRule}{\rule{\linewidth}{0.4pt}}\par}

\newcolumntype{Y}{>{\RaggedRight\arraybackslash}X}

%% ---- Small badges ---------------------------------------------------------
% \PillBadge{fill-color}{text-color}{label} — tiny rounded label.
\newcommand{\PillBadge}[3]{%
  \begin{tikzpicture}[baseline=(p.base)]
    \node[
      fill=#1, text=#2, rounded corners=1.8pt,
      inner xsep=2.9pt, inner ysep=0.68pt,
      font=\sffamily\scriptsize\bfseries
    ] (p) {#3};
  \end{tikzpicture}%
}

% \RainbowEmoji — Unicode rainbow 🌈 rendered through the Noto Color Emoji
% font. Sized down to fit a scriptsize pill (Noto Color Emoji's em is large).
\newcommand{\RainbowEmoji}{%
  {\EmojiFont\fontsize{6.5pt}{6.5pt}\selectfont🌈}%
}

% \TrophyIcons{n} — repeat 🏆 n times in Noto Color Emoji (DejaVu has no U+1F3C6).
\newcommand{\TrophyEmoji}{%
  {\EmojiFont\fontsize{6.5pt}{6.5pt}\selectfont🏆}%
}
\newcommand{\TrophyIcons}[1]{%
  \ifnum#1<1\relax\else
    \TrophyEmoji
    \ifnum#1>1
      \hspace{0.6pt}\expandafter\TrophyIcons\expandafter{\the\numexpr#1-1\relax}%
    \fi
  \fi
}

% \LgbtqPill{label} — soft violet pill prefixed with the rainbow emoji.
% Song-page only; use \InfoColumnFont to match the left sidebar.
\newcommand{\LgbtqPill}[1]{%
  \ifblank{#1}{}{%
    \begin{tikzpicture}[baseline=(p.base)]
      \node[
        fill=BookletQueer!12, draw=BookletQueer!45, line width=0.3pt,
        text=BookletQueer!75!black, rounded corners=2pt,
        inner xsep=3.1pt, inner ysep=0.82pt,
        font=\InfoColumnFont\selectfont\scriptsize\bfseries
      ] (p) {\RainbowEmoji\hspace{1.65pt}#1};
    \end{tikzpicture}%
  }%
}

% \PlaceMarker — tiny TikZ-drawn drop pin, used as inline emoji-substitute next
% to a place name. Sized for scriptsize body text; baseline is set so the pin
% sits naturally next to lowercase letters. Color matches the booklet's deep
% blue accent so it reads as a place marker rather than a magenta alert.
\newcommand{\PlaceMarker}{%
  \begin{tikzpicture}[baseline=-0.3ex, x=1pt, y=1pt, line cap=round, line join=round]
    \fill[BookletAccent!72]
      (0,0)
      .. controls (-0.5,0.6) and (-2.4,1.3) .. (-2.4,3.2)
      arc[start angle=180, end angle=0, radius=2.4]
      .. controls (2.4,1.3) and (0.5,0.6) .. (0,0)
      -- cycle;
    \fill[white] (0,3.5) circle (0.85);
  \end{tikzpicture}%
}

% \YoutubeIcon — small red rounded badge with white play triangle.
\newcommand{\YoutubeIcon}{%
  \begin{tikzpicture}[baseline=-0.4ex, x=1pt, y=1pt]
    \fill[BookletYT, rounded corners=0.9pt] (0,0) rectangle (8.4,5.8);
    \fill[white] (3.0,1.4) -- (3.0,4.4) -- (5.6,2.9) -- cycle;
  \end{tikzpicture}%
}

% \SongLangIcon / \SongGenreIcon — inline emoji (Noto Color Emoji) before
% the language- / genre-pill rows; size matches \RainbowEmoji.
\newcommand{\SongLangIcon}{%
  {\EmojiFont\fontsize{6.5pt}{6.5pt}\selectfont🗣️}%
}
\newcommand{\SongGenreIcon}{%
  {\EmojiFont\fontsize{6.5pt}{6.5pt}\selectfont🎵}%
}

%% ---- Thumbnail frame (fixed-height, missing-asset placeholder) ------------
% \ThumbBox{height}{label-if-missing}{content}
\newcommand{\ThumbBox}[3]{%
  \begin{tikzpicture}[baseline=(box.north)]
    \node[draw=BookletRule, line width=0.4pt, rounded corners=1.2pt,
          inner sep=1.5pt, minimum height=#1, minimum width=\linewidth,
          fill=white, anchor=north west] (box) at (0,0) {%
      \ifblank{#3}{\color{BookletMuted}\scriptsize #2}{#3}%
    };
  \end{tikzpicture}%
}

%% ---- Hero band (country header) -------------------------------------------
% \HeroBand{flag-path}{country}{context-tag}{number}{vote-label}
% - flag-path: path to flag PDF or empty string (renders a flag-only left strip)
% - country:   large country name
% - context-tag: one line of context (variant-dependent), muted white
% - number:    large running number (empty for pre/post variants)
% - vote-label: word "Vote" / "Голосовать" (empty when number is empty), shown
%   before the number, same gold/sans/bold family as the digit
%
% When `number` is empty the right pane collapses and the title pane widens,
% so overall_pre / overall_post don't leave a visible chunk of empty blue.
\newcommand{\HeroBand}[5]{%
  \begin{tcolorbox}[
    enhanced, sharp corners, colback=BookletAccent, colframe=BookletAccent,
    left=4.6mm, right=4.6mm, top=2.7mm, bottom=2.7mm, boxrule=0pt,
    borderline north={1.0pt}{0pt}{BookletAccent2},
  ]
    \color{white}
    \noindent
    \begin{minipage}[c]{0.12\linewidth}%
      \ifblank{#1}{}{%
        \includegraphics[width=\linewidth, height=13mm, keepaspectratio]{#1}%
      }%
    \end{minipage}\hspace{4mm}%
    \ifblank{#4}{%
      % No running number → title pane takes the remaining width.
      \begin{minipage}[c]{\dimexpr0.88\linewidth-4mm\relax}%
        {\sffamily\fontsize{21pt}{23pt}\selectfont\bfseries\MixedBody{#2}}\par
        \ifblank{#3}{}{%
          \vspace{0.95mm}%
          {\sffamily\small\color{white!80}\MixedBody{#3}}\par
        }%
      \end{minipage}%
    }{%
      \begin{minipage}[c]{0.52\linewidth}%
        {\sffamily\fontsize{21pt}{23pt}\selectfont\bfseries\MixedBody{#2}}\par
        \ifblank{#3}{}{%
          \vspace{0.95mm}%
          {\sffamily\small\color{white!80}\MixedBody{#3}}\par
        }%
      \end{minipage}\hfill%
      % Vote word + running number: `m` columns vertically center the smaller
      % label against the tall digit; a wider pane fits ``Голосовать'' on one line.
      \begin{minipage}[c]{0.28\linewidth}%
        \raggedleft
        \begin{tabular}{@{}%
          >{\sffamily\bfseries\color{BookletGold}\raggedleft\arraybackslash}%
            m{\dimexpr\linewidth-2.85em\relax}%
          @{\hspace{2.4mm}}%
          >{\sffamily\bfseries\color{BookletGold}\centering\arraybackslash}%
            m{2.85em}@{}}
          \fontsize{15.5pt}{18.5pt}\selectfont #5 &
          \fontsize{26pt}{28pt}\selectfont #4
        \end{tabular}%
      \end{minipage}%
    }%
  \end{tcolorbox}%
}

% \ProbPill{fill}{label}{percent} — implied-probability pill (fill = BookletProbRed|Amber|Green).
% Example: \ProbPill{BookletProbRed}{Win}{1.2%}  \ProbPill{BookletProbGreen}{Qualify}{87%}
% The label identifies the bet type (winner vs qualifier). The bookmaker
% itself is intentionally not shown (minimal design).
\newcommand{\ProbPill}[3]{%
  \ifblank{#3}{}{%
    \begin{tikzpicture}[baseline=(pill.base)]
      \node[
        fill=#1, text=BookletInk, rounded corners=2pt,
        inner xsep=2.85pt, inner ysep=1.2pt,
        font=\InfoColumnFont\selectfont\bfseries\small
      ] (pill) {{\scriptsize #2}\hspace{1.45pt}#3};
    \end{tikzpicture}%
  }%
}

% \MetaPill{label}  — tiny outlined pill for genres / languages / selection tags.
% Song-page only; \InfoColumnFont matches the left sidebar.
\newcommand{\MetaPill}[1]{%
  \ifblank{#1}{}{%
    \begin{tikzpicture}[baseline=(p.base)]
      \node[
        draw=BookletRule, line width=0.3pt, fill=BookletSoft, text=BookletInk,
        rounded corners=2pt, inner xsep=3.15pt, inner ysep=0.75pt,
        font=\InfoColumnFont\selectfont\scriptsize
      ] (p) {#1};
    \end{tikzpicture}%
  }%
}

% \MetaPillMuted{label}  — same as MetaPill but text is muted (used for minor langs).
\newcommand{\MetaPillMuted}[1]{%
  \ifblank{#1}{}{%
    \begin{tikzpicture}[baseline=(p.base)]
      \node[
        draw=BookletRule, line width=0.3pt, fill=BookletSoft, text=BookletMuted,
        rounded corners=2pt, inner xsep=3.15pt, inner ysep=0.75pt,
        font=\InfoColumnFont\selectfont\scriptsize
      ] (p) {#1};
    \end{tikzpicture}%
  }%
}

% \VideoLink{url}{label}  — small muted video/play link.
\newcommand{\VideoLink}[2]{%
  \ifblank{#1}{}{%
    {\scriptsize\Muted{\textbullet\,\href{#1}{#2}}}%
  }%
}

% \VideoLinkFooter{url}{label} — page-footer variant: YouTube icon + underlined,
% colored, sans-serif label. Used by \SetSongFooter so the bottom-right of each
% song page advertises the official video / national selection links.
\newcommand{\VideoLinkFooter}[2]{%
  \ifblank{#1}{}{%
    \href{#1}{%
      \raisebox{-0.06ex}{\YoutubeIcon}\hspace{2.0pt}%
      {\sffamily\footnotesize\bfseries\color{BookletAccent}\underline{#2}}%
    }%
  }%
}

%% ---- Info panels ----------------------------------------------------------
% \InfoPanel{title}{body}
% `baseline=0pt` anchors the tcolorbox baseline at the top edge of the box so
% `minipage[t]` columns containing an infopanel line up on the title row,
% regardless of how tall each column's content is. Without it, panels drift
% vertically based on first-line metrics of their first content element.
\newtcolorbox{infopanel}[1]{%
  enhanced, arc=2.4pt,
  colback=BookletSoft, colframe=BookletRule,
  boxrule=0.3pt, left=2.8mm, right=2.2mm, top=2.35mm, bottom=2.45mm,
  baseline=0pt, before=\noindent, after=\relax,
  % Ragged like the outer \RaggedRight (tcolorbox’s default is justified).
  halign=flush left,
  fonttitle={\InfoColumnFont\selectfont\footnotesize\bfseries\color{BookletAccent}},
  title={#1},
  coltitle=BookletAccent,
  attach boxed title to top left={yshift=-2.1pt, xshift=2.5mm},
  boxed title style={colback=white, colframe=white, sharp corners,
    size=minimal, top=0.35pt, bottom=0pt, left=2.1pt, right=2.1pt}
}

% \FactChip{text} — a single-line "fact card" rendered as a tiny rounded
% white box on the soft-grey panel background. Used for bio / song-facts /
% country-facts lines so each individual factoid reads as its own discrete
% chip rather than one paragraph blob. Long lines wrap inside the chip.
\newtcolorbox{factchip}{%
  enhanced, arc=2.0pt,
  colback=white, colframe=BookletRule,
  boxrule=0.3pt,
  % Full panel width: wrapping matches the infopanel; tight inner padding on the
  % right so lines do not end short of the card edge.
  width=\linewidth,
  left=2.0pt, right=1.3pt, top=1.15pt, bottom=1.45pt,
  before skip=0pt, after skip=0.78mm,
  baseline=0pt, before=\noindent, after=\relax,
  halign=flush left,
  % Song page only: match \InfoColumnFont so tcolorbox does not force \sffamily.
  fontupper={\InfoColumnFont\selectfont\scriptsize},
}
\newcommand{\FactChip}[1]{\begin{factchip}#1\end{factchip}}

%% ---- Lyrics blocks --------------------------------------------------------
% Lyrics live in a single tall column on the right side of the page (see the
% \SongPage macro). The block is a 2-cell tabularx (original | translation)
% running the full height of the page, so each line of the song is exactly
% one row. Lines that don't fit horizontally are NOT wrapped — instead the
% font size is chosen so that typical lines fit, and the few that don't are
% expected to be edited at the source.
%
% \LyricsTall{rows}  — paired original | translation, full column width.
% Inside lyrics, render Latin AND Cyrillic with DejaVu Sans Condensed.
% Polyglossia's `\setdefaultlanguage{russian}` makes the document's default
% script Cyrillic, which auto-swaps to the (regular-width) `\cyrillicfont`
% for every glyph and silently overrides any local font selection. Wrapping
% the lyrics block in `\foreignlanguage{english}{...}` switches the language
% back to English; AFTER that switch we apply `\LyricsFont` (Condensed) so
% all glyphs — including Cyrillic — are rendered narrower.
% \LyricsTall{font-pt}{baseline-pt}{rows}
\newcommand{\LyricsTall}[3]{%
  \begingroup
  \setlength{\tabcolsep}{7pt}%
  \renewcommand{\arraystretch}{1.0}%
  \foreignlanguage{english}{%
    \LyricsFont
    \fontsize{#1pt}{#2pt}%
    \renewcommand{\baselinestretch}{1.0}%
    \selectfont
    \begin{tabularx}{\linewidth}{@{}Y Y@{}}#3\end{tabularx}%
  }%
  \endgroup
}

% \LyricsTallSolo{font-pt}{baseline-pt}{rows}  — single-column (no translation), full width.
\newcommand{\LyricsTallSolo}[3]{%
  \begingroup
  \setlength{\tabcolsep}{0pt}%
  \renewcommand{\arraystretch}{1.0}%
  \foreignlanguage{english}{%
    \LyricsFont
    \fontsize{#1pt}{#2pt}%
    \renewcommand{\baselinestretch}{1.0}%
    \selectfont
    \begin{tabularx}{\linewidth}{@{}Y@{}}#3\end{tabularx}%
  }%
  \endgroup
}

% Stanza gap row in lyrics tables — renders as whitespace only.
% A bit more generous than line spacing so stanza boundaries are visually
% distinct from line breaks.
\newcommand{\LyricsGap}{%
  \noalign{\vspace{1.65mm}}%
}

\newcommand{\LyricsSoloGap}{%
  \noalign{\vspace{1.65mm}}%
}

% Lyrics block header sitting at the top of the right column.
% \LyricsHeader{orig-title}{trans-title} — two columns matching the lyrics
% tabularx grid: the original-language song title sits over the original
% column, and its translation sits over the translation column.
\newcommand{\LyricsHeader}[2]{%
  \begingroup
  \setlength{\tabcolsep}{7pt}%
  \renewcommand{\arraystretch}{1.0}%
  \sffamily\footnotesize\bfseries\color{BookletAccent}%
  \begin{tabularx}{\linewidth}{@{}Y Y@{}}%
    {\setstretch{0.90}\RaggedRight\MixedBody{#1}} & {\setstretch{0.84}\RaggedRight\MixedBody{#2}}%
  \end{tabularx}%
  \endgroup\par
  \vspace{1.15mm}%
  {\color{BookletAccent!30}\rule{\linewidth}{0.3pt}}\par
  \vspace{2.25mm}%
}

% \LyricsHeaderSolo{title} — same look, single column for solo (no-translation) songs.
\newcommand{\LyricsHeaderSolo}[1]{%
  {\sffamily\footnotesize\bfseries\color{BookletAccent}\MixedBody{#1}}\par
  \vspace{1.15mm}%
  {\color{BookletAccent!30}\rule{\linewidth}{0.3pt}}\par
  \vspace{2.25mm}%
}

%% ---- Song page scaffold (force one country per page) ---------------------
% \SongPage{hero}{panels-stack}{lyrics-tall}
% Layout: hero, then a two-column body (left: info panels, right: aligned
% lyrics tabular, both top-aligned). A page break ends each country. Avoid a
% single outer minipage of \textheight — it can produce blank pages.
% Widths are tuned so that lyric lines up to ~50 Latin / ~45 Cyrillic chars
% fit per sub-column without wrapping at the chosen font size (see
% scripts/build.py: _LYRICS_WRAP_BUDGET_* (paired with the lyrics minipage width).
% Do not use a \textheight-tall minipage here: a fixed-height outer box
% interacts badly with the unbreakable inner layout (tcolorbox, tall lyrics
% tabular) and with the page break at the end of each country, producing
% an extra empty page after some country pages. Top-aligned natural-height
% minipages + one \newpage keep
% one country per page without stray blanks.
\newcommand{\SongPage}[3]{%
  \begingroup
  \setlength{\parskip}{0pt}%
  \noindent
  % Keep the hero and the two body minipages in one unbreakable \vbox. If we
  % do not, TeX is allowed to page-break between the short hero tcolorbox and
  % the much taller minipages when the minipages do not fit the remainder of
  % the current page. That looks like a half-empty (``blank'') first page
  % with only the blue band, full content on the next page — and +1 per song
  % when the left column and/or wrapped lyrics are taller (common in RU).
  \vbox{%
    #1\par
    \vspace{1.85mm}%
    \noindent
    % Iteration 1: widen info column (was 0.275) — fewer short, high-badness
    % lines. Lyrics column and Python wrap budgets are adjusted to match.
    \begin{minipage}[t]{0.30\linewidth}\vspace*{0pt}%
      #2%
    \end{minipage}\hspace{0.015\linewidth}%
    \begin{minipage}[t]{0.685\linewidth}\vspace*{0pt}%
      #3%
    \end{minipage}%
  }%
  \endgroup
  % Next country on a fresh page. \newpage avoids the float-flush in
  % \clearpage, which with this unbreakable \vbox layout can otherwise
  % insert an extra nearly-empty page between countries under LuaLaTeX.
  \newpage
}
