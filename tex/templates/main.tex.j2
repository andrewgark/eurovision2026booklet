\documentclass[11pt]{article}

\usepackage{booklet}

% Language selection
{% if lang == "ru" %}
\setdefaultlanguage{russian}
{% else %}
\setdefaultlanguage{english}
{% endif %}

\hypersetup{
  colorlinks=true,
  linkcolor=BookletAccent,
  urlcolor=BookletAccent
}

\begin{document}

% Page 1: Cover (centered) + contents
\thispagestyle{empty}
\noindent
\begin{minipage}{\linewidth}
\centering
\CoverBookletLabel{ {{ booklet_title }} }\\[0.9em]
\CoverEventHeadline{ {{ event_name }} }%
{% if cover_subtitle %}
\par\vspace{0.5em}
\CoverSubtagline{ {{ cover_subtitle }} }%
{% endif %}
\end{minipage}
\vspace{2.8mm}
\begingroup
\setstretch{0.9}%
\TocSectionTitle{ {% if lang == "ru" %}Содержание{% else %}Contents{% endif %} }
{% if lang == "ru" %}\TocItemLink{toc-about}{Про Евровидение}
{% else %}\TocItemLink{toc-about}{About}
{% endif %}
{% for e in entries %}
\TocItemLink{song-{{ e.country_code }}}{% if e.toc_index_prefix %}{{ e.toc_index_prefix }}{% endif %}\TocFlagEmoji{ {{ e.toc_flag_emoji }} }{{ e.country_name }} — {{ e.song_title }} }
{% endfor %}
{% if mode == "post" %}{% if lang == "ru" %}\TocItemLink{toc-results}{Результаты}{% else %}\TocItemLink{toc-results}{Results}{% endif %}{% endif %}
\endgroup
\newpage

% Page 2: intro (variant-specific intro_text_* with fallback to legacy about_text)
\leavevmode\phantomsection\label{toc-about}%
\SectionTitle{ {% if lang == "ru" %}Про Евровидение{% else %}About{% endif %} }
{% if intro_text %}
\begin{introtextbox}
{{ intro_text }}
\end{introtextbox}
{% endif %}
\newpage

% Song pages (\SongPage ends with \newpage for the next country).
{% for e in entries %}
{% include "song_page.tex.j2" %}
{% endfor %}

% Post-contest results page (placeholder until results.json is populated).
{% if mode == "post" %}
\leavevmode\phantomsection\label{toc-results}%
\SectionTitle{ {% if lang == "ru" %}Результаты{% else %}Results{% endif %} }
\Muted{ {% if lang == "ru" %}Данные из базы знаний. Заполните таблицу results в Google Sheets.{% else %}Data comes from the knowledge base. Fill the results tab in Google Sheets.{% endif %} }\par
{% endif %}

\end{document}

