{%- set L_ABOUT_COUNTRY = "Страна"      if lang == "ru" else "Country" -%}
{%- set L_ABOUT_ARTIST  = "Исполнитель" if lang == "ru" else "Artist" -%}
{%- set L_ABOUT_SONG    = "Песня"       if lang == "ru" else "Song" -%}
{%- set L_BORN          = "р." if lang == "ru" else "b." -%}
{%- set L_WIN           = "Победа"  if lang == "ru" else "Win" -%}
{%- set L_QUALIFY       = "В финал" if lang == "ru" else "Qualify" -%}
{%- set L_BOOKIES       = "Букмекеры считают:" if lang == "ru" else "Bookies expect:" -%}
{%- set L_NF            = "Нацотбор"     if lang == "ru" else "National selection" -%}
{%- set L_MV            = "Клип"         if lang == "ru" else "Official video" -%}
\SongPage{
\SetSongFooter{ {%- if e.national_final_url or e.music_video_url %}{%- if e.national_final_url %}\VideoLinkFooter{ {{- e.national_final_url -}} }{ {{ L_NF }} }{% endif %}{% if e.national_final_url and e.music_video_url %}\hspace{2.0mm}{\color{BookletMuted}\scriptsize\textbullet}\hspace{2.0mm}{% endif %}{% if e.music_video_url %}\VideoLinkFooter{ {{- e.music_video_url -}} }{ {{ L_MV }} }{% endif %}{%- endif %} }
\leavevmode\phantomsection\label{song-{{ e.country_code }}}%
  \HeroBand
    { {{ e.flag_path or "" }} }
    { {{ e.country_name }} }
    { {{ e.context_tag or "" }} }
    { {{ e.number_label or "" }} }
    { {{ e.vote_label or "" }} }
}{
% LEFT column: stacked Artist / Country / Song panels.
% Iteration 2+3: condensed measure + a bit of emergencystretch in this minipage.
\begingroup
\InfoColumnFont\selectfont
\setlength{\emergencystretch}{1.75em}
% Iteration 5: give TeX more line-break options in this narrow ragged column
% (\hbadness is already 10000 in booklet.sty for cosmetic underfull noise).
\pretolerance=200
\tolerance=3000
% --- Artist -------------------------------------------------------------
\begin{infopanel}{ {{ L_ABOUT_ARTIST }} }
\setstretch{1.06}\RaggedRight
{% if e.photo_path %}
\begin{minipage}[t]{\linewidth}\vspace*{0pt}
\includegraphics[width=\linewidth, height=44mm, keepaspectratio]{ {{ e.photo_path }} }
\end{minipage}
\par\vspace{1.45mm}
{% endif %}
\begin{minipage}[t]{\linewidth}\vspace*{0pt}
{% for line in e.artist_name_lines %}
{\InfoNameLine{ {{ line }} }}\par
{% if not loop.last %}\vspace{0.10mm}{% endif %}
{% endfor %}
{% if e.artist_birth_name_lines %}\vspace{-0.30\baselineskip}{% endif %}
{% for line in e.artist_birth_name_lines %}
{\scriptsize\Muted{\InfoMixedBody{ {{ line }} }}}\par
{% if not loop.last %}\vspace{-0.34\baselineskip}{% endif %}
{% endfor %}
{% if e.artist_birth_year or e.artist_birth_place or e.artist_grew_up or e.artist_lgbtq %}
\vspace{0.55mm}\par
{% elif e.artist_birth_name_lines %}
\vspace{0.32mm}\par
{% endif %}
{% if e.artist_birth_year %}{\scriptsize\Muted{ {{ L_BORN }}\,{{ e.artist_birth_year }} }}\par{% endif %}
{% if e.artist_birth_place %}{\scriptsize\Muted{\PlaceMarker\,\InfoMixedBody{ {{ e.artist_birth_place }} }}}\par{% endif %}
{% if e.artist_grew_up and e.artist_grew_up != e.artist_birth_place %}{\scriptsize\Muted{\textrightarrow\,\InfoMixedBody{ {{ e.artist_grew_up }} }}}\par{% endif %}
{% if e.artist_lgbtq %}\vspace{0.62mm}\LgbtqPill{ {{ e.artist_lgbtq }} }\par{% endif %}
\end{minipage}
{% if e.bio_lines %}\par\vspace{1.45mm}\scriptsize\setstretch{1.06}\RaggedRight
{% for line in e.bio_lines %}\FactChip{ {{ line }} }
{% endfor %}{% endif %}
\end{infopanel}
\par\vspace{1.85mm}
% --- Country ------------------------------------------------------------
\begin{infopanel}{ {{ L_ABOUT_COUNTRY }} }
\scriptsize\setstretch{1.06}\RaggedRight
{% if e.qualify_percent or e.win_percent %}
{\scriptsize\Muted{ {{ L_BOOKIES }} }}\par
\vspace{0.52mm}\par
{% if e.qualify_percent %}\ProbPill{ {{ L_QUALIFY }} }{ {{ e.qualify_percent }} }{% if e.win_percent %}\hspace{0.95mm}{% endif %}{% endif %}
{% if e.win_percent %}\ProbPill{ {{ L_WIN }} }{ {{ e.win_percent }} }{% endif %}
\par
{% endif %}
{% if e.country_stats_lines %}
\vspace{0.92mm}\par
{% for s in e.country_stats_lines %}{\color{BookletAccent!50}\textbullet}\,{\Muted{ {{ s }} }}\par
{% endfor %}
{% endif %}
{% if e.selection_tag %}\vspace{0.72mm}\MetaPill{ {{ e.selection_tag }} }\par{% endif %}
{% if e.country_facts_lines %}\vspace{1.25mm}\par\setstretch{1.06}\RaggedRight
{% for line in e.country_facts_lines %}\FactChip{ {{ line }} }
{% endfor %}{% endif %}
\end{infopanel}
\par\vspace{1.85mm}
% --- Song ---------------------------------------------------------------
\begin{infopanel}{ {{ L_ABOUT_SONG }} }
\setstretch{1.06}\RaggedRight
{\InfoNameLine{ {{ e.song_title }} }}\par
{% if e.song_title_translation %}\vspace{-0.26\baselineskip}{\setstretch{0.88}\scriptsize\Muted{\InfoMixedBody{ {{ e.song_title_translation }} }}\par}{% endif %}
{% if e.langs_major or e.langs_minor %}
\vspace{1.05mm}\par\noindent
\raisebox{0.05ex}{\SongLangIcon}\hspace{1.5mm}%
{% for t in e.langs_major %}\MetaPill{ {{ t }} }\hspace{0.68mm}{% endfor %}{% for t in e.langs_minor %}\MetaPillMuted{ {{ t }} }\hspace{0.68mm}{% endfor %}
\par
{% endif %}
{% if e.genres %}
\vspace{0.78mm}\par\noindent
\raisebox{0.05ex}{\SongGenreIcon}\hspace{1.5mm}%
{% for t in e.genres %}\MetaPill{ {{ t }} }\hspace{0.68mm}{% endfor %}
\par
{% endif %}
{% if e.facts_lines %}\vspace{1.25mm}\par\scriptsize\setstretch{1.06}\RaggedRight
{% for line in e.facts_lines %}\FactChip{ {{ line }} }
{% endfor %}{% endif %}
\end{infopanel}
\endgroup
}{
% RIGHT column: a single tall lyrics column running the full body height.
{% if not e.has_translation %}
\LyricsHeaderSolo{ {{ e.song_title }} }
\LyricsTallSolo{ {{ e.lyrics_font_pt }} }{ {{ e.lyrics_baseline_pt }} }{
{% for row in e.lyrics_rows %}
{% if row.kind == "gap" %}\LyricsSoloGap
{% else %}{{ row.orig }}\\
{% endif %}
{% endfor %}
}
{% else %}
\LyricsHeader{ {{ e.song_title }} }{ {{ e.song_title_translation or "" }} }
\LyricsTall{ {{ e.lyrics_font_pt }} }{ {{ e.lyrics_baseline_pt }} }{
{% for row in e.lyrics_rows %}
{% if row.kind == "gap" %}\LyricsGap
{% else %}{{ row.orig }} & \Muted{ {{ row.trans }} }\\
{% endif %}
{% endfor %}
}
{% endif %}
}
